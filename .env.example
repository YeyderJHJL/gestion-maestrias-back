# Docker development
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# CORS allowed origins for development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production profile
SERVER_PORT=8080
DB_URL=jdbc:postgresql://postgres:5432/postgres # jdbc:postgresql://host:5432/db_name
DB_USER=root
DB_PASSWORD=root
DB_POOL_MAX=12
DB_POOL_MIN_IDLE=4
DB_CONNECTION_TIMEOUT=20000

# Google Cloud (production)
GCP_PROJECT_ID=my-gcp-project
GCS_BUCKET=my-gcs-bucket
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json

# OAuth2 Google — client ID used as JWT audience
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_ISSUER_URI=https://accounts.google.com
GOOGLE_OAUTH_AUDIENCE=xxxx.apps.googleusercontent.com

# Seeds
ADMIN_EMAIL=user@unsa.edu.pe

# File upload limits
MAX_FILE_SIZE=20MB
MAX_REQUEST_SIZE=25MB