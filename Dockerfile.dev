# syntax=docker/dockerfile:1.7
FROM eclipse-temurin:25-jdk-noble

ARG GRADLE_VERSION=9.4.1

WORKDIR /app

RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends wget unzip \
    && rm -rf /var/lib/apt/lists/* \
    && wget -qO /tmp/gradle.zip \
        https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip \
    && unzip -q /tmp/gradle.zip -d /opt \
    && ln -s /opt/gradle-${GRADLE_VERSION}/bin/gradle /usr/local/bin/gradle \
    && rm /tmp/gradle.zip

COPY docker/dev-api.sh /usr/local/bin/dev-api
RUN chmod +x /usr/local/bin/dev-api

ENV SPRING_PROFILES_ACTIVE=dev
ENV ENABLE_DEBUG=true
ENV GRADLE_USER_HOME=/home/gradle/.gradle
ENV GRADLE_OPTS="-Xmx512m"
ENV STORAGE_EMULATOR_HOST=http://gcs:4443
ENV GCP_PROJECT_ID=masters-dev
ENV GCS_BUCKET=masters-dev

EXPOSE 8080 5005 35729

CMD ["dev-api"]
