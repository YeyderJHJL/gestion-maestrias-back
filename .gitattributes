# Force Unix line endings for scripts executed in Linux containers
gradlew        text eol=lf
gradlew.bat    text eol=crlf
*.sh           text eol=lf
*.sql          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.properties   text eol=lf
*.java         text eol=lf
*.gradle       text eol=lf
*.md           text eol=lf
*.html         text eol=lf
*.conf         text eol=lf

# Binary files — no line ending conversion
*.jar          binary
*.png          binary
*.jpg          binary
*.pdf          binary
